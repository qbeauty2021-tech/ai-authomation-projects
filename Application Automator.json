      "name": "Gemini AI Scorer",
      "retryOnFail": true,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const text = $input.item.json.candidates[0].content.parts[0].text;\nconst cleaned = text.replace(/```json|```/g, \"\").trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  parsed = { score: 0, reason: \"Could not parse\", applyUrl: null };\n}\n\nreturn {\n  json: {\n    title: $input.item.json.title || \"\",\n    company: $input.item.json.company || \"\",\n    location: $input.item.json.location || \"\",\n    source: $input.item.json.source || \"\",\n    description: $input.item.json.description || \"\",\n    aiScore: parsed.score,\n    aiReason: parsed.reason,\n    applyUrl: parsed.applyUrl\n  }\n};"
      },
