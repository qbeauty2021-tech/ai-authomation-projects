    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst normalized = [];\n\nfor (const item of items) {\n  const job = item.json;\n\n  normalized.push({\n    json: {\n      title: job.title || job.position || job.job_title || \"\",\n      company: job.company || job.organization || job.company_name || \"\",\n      location: job.location || job.job_location || \"Remote\",\n      applyUrl: job.link || job.url || job.apply_url || job.job_url || \"\",\n      description: job.description || job.content || job.summary || \"\",\n      source: job.source || \"RSS Feed\",\n      postedAt: job.pubDate || job.published || job.date || \"\",\n      salary: job.salary || job.compensation || \"\",\n    }\n  });\n}\n\nreturn normalized;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -832,
        -128
      ],
      "id": "6e72c895-1413-44bb-8760-6e5893215e55",
      "name": "Normalise All Sources"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst allowed = [];\n\nconst blockedKeywords = [\n  \"india\", \"pakistan\", \"bangladesh\", \"philippines\",\n  \"indonesia\", \"brazil\", \"mexico\", \"china\", \"europe only\",\n  \"eu only\", \"latam\", \"latin america\"\n];\n\nconst allowedKeywords = [\n  \"remote\", \"worldwide\", \"global\", \"anywhere\",\n  \"nigeria\", \"abuja\", \"us\", \"usa\", \"united states\",\n  \"uk\", \"united kingdom\", \"canada\"\n];\n\nfor (const item of items) {\n  const location = (item.json.location || \"\").toLowerCase();\n  const title = (item.json.title || \"\").toLowerCase();\n  const description = (item.json.description || \"\").toLowerCase();\n\n  const isBlocked = blockedKeywords.some(keyword =>\n    location.includes(keyword) ||\n    description.includes(keyword + \" only\") ||\n    description.includes(keyword + \"-only\")\n  );\n\n  const isAllowed = allowedKeywords.some(keyword =>\n    location.includes(keyword)\n  );\n\n  if (!isBlocked && (isAllowed || location === \"\")) {\n    allowed.push(item);\n  }\n}\n\nreturn allowed;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -656,
        -256
      ],
      "id": "28c44c20-e7d6-4934-b305-f84e805c5d45",
      "name": "Geo Filter"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst matched = [];\n\nconst targetKeywords = [\n  \"automation\", \"n8n\", \"workflow\", \"ai automation\",\n  \"zapier\", \"make.com\", \"integromat\", \"no-code\",\n  \"low-code\", \"rpa\", \"robotic process\", \"process automation\",\n  \"ai engineer\", \"ai specialist\", \"integration engineer\",\n  \"chatbot\", \"llm\", \"langchain\", \"ai agent\"\n];\n\nfor (const item of items) {\n  const title = (item.json.title || \"\").toLowerCase();\n  const description = (item.json.description || \"\").toLowerCase();\n\n  const isMatch = targetKeywords.some(keyword =>\n    title.includes(keyword) || description.includes(keyword)\n  );\n\n  if (isMatch) {\n    matched.push(item);\n  }\n}\n\nreturn matched;"
      },
