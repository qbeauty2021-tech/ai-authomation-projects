    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst channel = data.rss?.channel?.[0] || data.rss?.channel;\nconst items = channel?.item || [];\n\nconst results = items.slice(0, 5).map(item => ({\n  json: {\n    title: Array.isArray(item.title) ? item.title[0] : item.title,\n    link: Array.isArray(item.link) ? item.link[0] : item.link,\n    publishedDate: Array.isArray(item.pubDate) ? item.pubDate[0] : item.pubDate\n  }\n}));\n\nreturn results;"
      },
