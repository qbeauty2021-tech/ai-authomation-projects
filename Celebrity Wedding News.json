    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst html = input.data || input.body || input.content || '';\n\nconst imgRegex = /<img[^>]+src=[\"']([^\"']+)[\"'][^>]*>/gi;\nconst matches = [...html.matchAll(imgRegex)];\n\nconst relevantImages = matches\n  .map(m => m[1])\n  .filter(src =>\n    !src.includes('logo') &&\n    !src.includes('icon') &&\n    !src.includes('ad') &&\n    !src.includes('avatar') &&\n    (src.startsWith('http') || src.startsWith('https'))\n  );\n\nreturn [{\n  json: {\n    title: $('Code in JavaScript').first().json.title,\n    link: $('Code in JavaScript').first().json.link,\n    publishedDate: $('Code in JavaScript').first().json.publishedDate,\n    image_url: relevantImages[0] || 'No image found'\n  }\n}];"
      },
